# ── Database ───────────────────────────────────────────────────────────────
# SQLite (development default — zero-config)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/seoulinkhealth?schema=public"

# ── Email / SMTP ───────────────────────────────────────────────────────────
# Gmail example (use App Password, not your login password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password"

# SendGrid example (alternative)
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="apikey"
# SMTP_PASS="SG.your-sendgrid-api-key"

# ── Company config ─────────────────────────────────────────────────────────
COMPANY_EMAIL="contact@seoulinkhealth.com"
DIRECTOR_NAME="Byung-Joo Kim"

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"
ADMIN_PASSWORD="change-me-to-a-secure-password"

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,https://seoulinkhealth.com,https://www.seoulinkhealth.com"
