# ─── SEOULINKHEALTH Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in the actual values.
# All Vite environment variables must be prefixed with VITE_

# ─── Contact ─────────────────────────────────────────────────────────────────
VITE_COMPANY_EMAIL=contact@seoulinkhealth.com
VITE_DIRECTOR_NAME=Byung-Joo Kim
VITE_WEBSITE=https://www.seoulinkhealth.com

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Set to 'true' to show the LOGIN menu item in the navigation
VITE_LOGIN_ENABLED=false

# ─── Email / SMTP (Server-side — used in API routes / backend) ───────────────
# These are NOT exposed to the client. Use a backend proxy or serverless function.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@seoulinkhealth.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=SEOULINKHEALTH <noreply@seoulinkhealth.com>

# ─── Admin ───────────────────────────────────────────────────────────────────
# Secret key for admin dashboard session / JWT (server-side only)
ADMIN_SECRET=change_this_to_a_secure_random_string

# ─── Backend API URL ─────────────────────────────────────────────────────────
# Development: point to the local Express backend
VITE_API_BASE_URL=http://localhost:3001/api
# Production: same-origin proxy (leave blank to default to /api)
# VITE_API_BASE_URL=https://api.seoulinkhealth.com/api

# ─── Database (optional — for persisted form submissions) ────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/seoulinkhealth
# Or use a simple JSON file / SQLite for MVP:
# DB_TYPE=sqlite
# DB_PATH=./data/submissions.db
